# Archivo de ejemplo de Variables de Entorno para Vite (.env)
# Renombra este archivo a .env en el servidor de producción o copia las variables en tu entorno de CI/CD.

# ── Analítica Web ──

# Google Analytics 4 (GA4) - Measurement ID
# Lo encuentras en el panel de GA4 > Administrador > Flujos de datos (Formato: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Meta / Facebook Pixel ID
# Lo encuentras en el Administrador de Eventos de Meta Business (Formato: 15 dígitos numéricos)
VITE_FB_PIXEL_ID=
